# Dependencies
node_modules/

# Build / output
dist/
build/
out/
*.tsbuildinfo

# Environment and secrets
.env
.env.local
.env.*.local
*.pem

# Local config overrides (personal/machine-specific settings)
config/server.json

# E2E encryption passphrase (secret — never commit)
config/e2e.json

# Logs and debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# Tool / agent folders (ignore all folders starting with .)
# Includes .ziti/ (OpenZiti identity files — secrets, must never be committed)
.*/
!.github/
!.vscode/

# Auto-generated skill symlinks (enabled skills for the server)
server/skills/enabled/*

# Optional
.cache/
coverage/
.nyc_output/

# User sandbox workspace (created by users for local AI coding sessions)
cocoa_workspace/
